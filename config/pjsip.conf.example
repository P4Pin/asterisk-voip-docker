[global]
type=global
user_agent=WinDockerAsterisk

[transport-udp]
type=transport
protocol=udp
bind=0.0.0.0:5060

[transport-tcp]
type=transport
protocol=tcp
bind=0.0.0.0:5060

; ===== USER 6001 =====
[6001]
type=endpoint
context=internal
disallow=all
allow=ulaw,alaw
auth=6001
aors=6001
direct_media=no
rtp_symmetric=yes
force_rport=yes
rewrite_contact=yes

[6001]
type=auth
auth_type=userpass
username=6001
password=CHANGE_ME

[6001]
type=aor
max_contacts=1
remove_existing=yes

; ===== USER 6002 =====
[6002]
type=endpoint
context=internal
disallow=all
allow=ulaw,alaw
auth=6002
aors=6002
direct_media=no
rtp_symmetric=yes
force_rport=yes
rewrite_contact=yes

[6002]
type=auth
auth_type=userpass
username=6002
password=CHANGE_ME

[6002]
type=aor
max_contacts=1
remove_existing=yes